              {
                \int_if_zero:nTF {#1}
                  { 12 }
                  {
                    \bool_lazy_or:nnTF
                      { \int_compare_p:nNn {#1} < { 10 } }
                      { \int_compare_p:n { 12 < #1 < 22 } }
                      { 0 \int_eval:n {#1} }
                      {
                        \int_compare:nNnTF {#1} < { 13 }
                          { \int_eval:n {#1} }
                          { \int_eval:n { \int_eval:n {#1} - 12 } }
                      }
                    }
              }
            }
        }
        { 24-hour }
        {
          \str_case:Vn \l_clockdate_clock_hour_format_str
            {
              { h } { \int_eval:n {#1} }
              { hh }
              {
                \int_compare:nNnT {#1} < { 10 } { 0 }
                \int_eval:n {#1}
              }
            }
        }
