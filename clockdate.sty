      {
        { 12-hour }
        {
          \str_case:Vn \l_clockdate_clock_hour_format_str
            {
              { h }
              {
                \int_if_zero:nTF {#1}
                  { 12 }
                  {
                    \int_compare:nNnTF {#1} < { 13 }
                      { \int_eval:n {#1} }
                      { \int_eval:n { \int_eval:n {#1} - 12 } }
                  }
