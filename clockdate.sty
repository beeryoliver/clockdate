  }
\prg_new_conditional:Npnn \__clockdate_date_year_month_day_if_valid:n #1 { TF }
  {
    \bool_lazy_any:nTF
      {
        { \int_compare_p:n { 0 < #1 < 29 } }
        {
          \bool_lazy_and_p:nn
            { \int_compare_p:nNn {#1} = { 31 } }
            { \__clockdate_date_month_if_thirty_one_days_p: }
        }
        {
          \bool_lazy_and_p:nn
            { \int_compare_p:nNn {#1} = { 30 } }
            { ! \int_compare_p:nNn \l_clockdate_date_month_int = 2 }
        }
        {
          \bool_lazy_and_p:nn
            { \int_compare_p:nNn {#1} = { 29 } }
            {
              \bool_lazy_or_p:nn
                { ! \int_compare_p:nNn \l_clockdate_date_month_int = 2 }
                { \__clockdate_date_year_if_leap_p: }
            }
        }
      }
      { \prg_return_true: } { \prg_return_false: }
