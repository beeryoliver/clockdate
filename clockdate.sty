\cs_new_protected:Npn \__clockdate_clock_print:nNNN #1#2#3#4
  {
    \seq_set_split:Nnn \l__clockdate_tmp_seq { : } {#1}
    \int_case:nnF { \seq_count:N \l__clockdate_tmp_seq - 1 }
      {
        { 0 } { \__clockdate_clock_set_hour:Nn #2 {#1} }
        { 1 }
        { \__clockdate_clock_set_hour_minute:NNw #2 #3 #1 \q__clockdate_stop }
      }
      {
        \__clockdate_clock_set_hour_minute_second:NNNw #2 #3 #4 #1
          \q__clockdate_stop
      }
  }
\cs_new_protected:Npn \__clockdate_clock_set_hour:Nn #1#2
  {
    \int_set:Nn #1 {#2}
    \int_compare:nF { 0 <= #1 < 25 }
      {
        \msg_error:nnV { clockdate } { hour-invalid } #1
        \prg_break:
      }
  }
\cs_new_protected:Npn \__clockdate_clock_set_hour_minute:NNw
  #1#2#3 : #4 \q__clockdate_stop
  {
    \int_set:Nn #1 {#3}
    \int_set:Nn #2 {#4}
    \int_compare:nF { 0 <= #1 < 25 }
      { \prg_break:n { \use:n } }
    \int_compare:nNnTF #1 = { 24 }
      {
        \int_if_zero:nF {#2}
          { \prg_break:n { \use:n } }
      }
      {
        \int_compare:nF { 0 <= #2 < 60 }
          { \prg_break:n { \use:n } }
      }
    \use_none:nn
    \prg_break_point:
      {
        \msg_error:nnVV { clockdate } { hour-minute-invalid } #1 #2
        \prg_break:
      }
  }
\cs_new_protected:Npn \__clockdate_clock_set_hour_minute_second:NNNw
  #1#2#3#4 : #5 : #6 \q__clockdate_stop
  {
    \int_set:Nn #1 {#4}
    \int_set:Nn #2 {#5}
    \int_set:Nn #3 {#6}
    \int_compare:nF { 0 <= #1 < 25 }
      { \prg_break:n { \use:n } }
    \int_compare:nNnTF #1 = { 24 }
      {
        \int_if_zero:nF {#2}
          { \prg_break:n { \use:n } }
        \int_if_zero:nF {#3}
          { \prg_break:n { \use:n } }
      }
      {
        \int_compare:nF { 0 <= #2 < 60 }
          { \prg_break:n { \use:n } }
        \int_compare:nF { 0 <= #3 < 61 }
          { \prg_break:n { \use:n } }
      }
    \use_none:nn
    \prg_break_point:
      {
        \msg_error:nnVVV { clockdate } { hour-minute-second-invalid } #1 #2 #3
        \prg_break:
      }
  }
\cs_new_protected:Npn \__clockdate_clock_print_hour:n #1
  {
    \str_case:Vn \l_clockdate_clock_clock_str
      {
        { 12-hour }
        {
          \str_case:Vn \l_clockdate_clock_hour_format_str
            {
              { h }
              {
                \int_if_zero:nTF {#1}
                  { 12 }
                  {
                    \int_compare:nNnTF {#1} < { 13 }
                      { \int_eval:n {#1} }
                      { \int_eval:n { \int_eval:n {#1} - 12 } }
                  }
              }
              { hh }
              {
                \int_if_zero:nTF {#1}
                  { 12 }
                  {
                    \bool_lazy_or:nnTF
                      { \int_compare_p:nNn {#1} < { 10 } }
                      { \int_compare_p:n { 12 < #1 < 22 } }
                      { 0 \int_eval:n {#1} }
                      {
                        \int_compare:nNnTF {#1} < { 13 }
                          { \int_eval:n {#1} }
                          { \int_eval:n { \int_eval:n {#1} - 12 } }
                      }
                    }
              }
            }
        }
        { 24-hour }
        {
          \str_case:Vn \l_clockdate_clock_hour_format_str
            {
              { h } { \int_eval:n {#1} }
              { hh }
              {
                \int_compare:nNnT {#1} < { 10 } { 0 }
                \int_eval:n {#1}
              }
            }
        }
      }
  }
\cs_new_protected:Npn \__clockdate_clock_print_minute:n #1
  {
    \str_case:Vn \l_clockdate_clock_minute_format_str
      {
        { m } { \int_eval:n {#1} }
        { mm }
        {
          \int_compare:nNnT {#1} < { 10 } { 0 }
          \int_eval:n {#1}
        }
      }
  }
\cs_new_protected:Npn \__clockdate_clock_print_second:n #1
  {
    \str_case:Vn \l_clockdate_clock_second_format_str
      {
        { s } { \int_eval:n {#1} }
        { ss }
        {
          \int_compare:nNnT {#1} < { 10 } { 0 }
          \int_eval:n {#1}
        }
      }
  }
\cs_new_protected:Npn \__clockdate_clock_print_ampm:n #1
  {
    \l_clockdate_clock_ampm_separator_tl
    \__clockdate_clock_hour_if_am:nTF {#1}
      {
        \str_case:Vn \l_clockdate_clock_ampm_format_str
          {
            { a.m. } { a.m \__clockdate_clock_ampm_period: }
            { am   } { am }
            { a    } { a }
            { A.M. } { A.M \__clockdate_clock_ampm_period: }
            { AM   } { AM \@ }
            { A    } { A \@ }
          }
      }
      {
        \str_case:Vn \l_clockdate_clock_ampm_format_str
          {
            { a.m. } { p.m \__clockdate_clock_ampm_period: }
            { am   } { pm }
            { a    } { p }
            { A.M. } { P.M \__clockdate_clock_ampm_period: }
            { AM   } { PM \@ }
            { A    } { P \@ }
          }
      }
  }
