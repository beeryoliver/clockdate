\prg_new_conditional:Npnn \__clockdate_date_month_day_if_valid:n #1 { TF }
  {
    \bool_lazy_any:nTF
      {
        { \int_compare_p:n { 0 < #1 < 30 } }
        {
          \bool_lazy_and_p:nn
            { \int_compare_p:nNn {#1} = { 31 } }
            { \__clockdate_date_month_if_thirty_one_days_p: }
        }
        {
          \bool_lazy_and_p:nn
            { \int_compare_p:nNn {#1} = { 30 } }
            { ! \int_compare_p:nNn \l_clockdate_date_month_int = 2 }
        }
      }
      { \prg_return_true: } { \prg_return_false: }
  }
% Tests if the year is a leap year according to the Julian calendar.
% The historic Julian calendar has more leap years than the Gregorian calendar.
\prg_new_conditional:Npnn \__clockdate_date_year_if_leap: { p }
  {
    \int_compare:nNnTF
      { \int_div_truncate:nn { \l_clockdate_date_year_int } { 4 } * 4 } =
      \l_clockdate_date_year_int
      { \prg_return_true: } { \prg_return_false: }
  }
\prg_new_conditional:Npnn \__clockdate_date_month_if_thirty_one_days: { p }
  {
    \int_case:nn { \l_clockdate_date_month_int }
      {
        {  1 } { \prg_return_true:  }
        {  2 } { \prg_return_false: }
        {  3 } { \prg_return_true:  }
        {  4 } { \prg_return_false: }
        {  5 } { \prg_return_true:  }
        {  6 } { \prg_return_false: }
        {  7 } { \prg_return_true:  }
        {  8 } { \prg_return_true:  }
        {  9 } { \prg_return_false: }
        { 10 } { \prg_return_true:  }
        { 11 } { \prg_return_false: }
        { 12 } { \prg_return_true:  }
      }
  }

